	(text "USB Replug Dongle Rev.C.1 - cost-optimized JLCPCB Economic PCBA"
		(exclude_from_sim no)
		(at 16.51 15.24 0)
		(effects (font (size 1.6 1.6) (bold yes)) (justify left bottom))
		(uuid "539e2431-ede0-421b-a869-58b95913c854")
	)
	(text "Host -> CH334U hub. Port 1 -> CH552T control MCU (always connected). Port 2 -> FSUSB42 data disconnect + TPS2552 VBUS disconnect -> DUT."
		(exclude_from_sim no)
		(at 16.51 181.61 0)
		(effects (font (size 1.15 1.15)) (justify left bottom))
		(uuid "a24960d4-7849-4201-973a-2d8e02d466fa")
	)
	(text "Reset-safe invariant: PWR_EN_N is 5 V high/OFF; equal 5.1k /OE divider is 2.65 V max at POR and 1.56 V min after release, keeping FSUSB disconnected without exceeding VCC."
		(exclude_from_sim no)
		(at 16.51 190.5 0)
		(effects (font (size 1.15 1.15)) (justify left bottom))
		(uuid "dfed45b5-0d2a-4eed-83da-a1787c3c6c54")
	)
	(text "Firmware ON: drive DATA_CMD low, delay, drive PWR_EN_N low. OFF: drive DATA_CMD high, then PWR_EN_N high. FAULT_N is 5 V-domain open-drain with a 5.1k pull-up."
		(exclude_from_sim no)
		(at 16.51 199.39 0)
		(effects (font (size 1.15 1.15)) (justify left bottom))
		(uuid "5f549a7a-a927-43b1-a9d1-89ba51e2c39c")
	)
	(text "CH334U RESET#/CDP is un-driven per WCH guidance (internal POR/pull-up); PSELF is tied low for bus power. TP8 permits manual low reset; U2 P3.1, hub ports 3/4/control/LED pins, and FSUSB throw 2 are NC."
		(exclude_from_sim no)
		(at 16.51 208.28 0)
		(effects (font (size 1.15 1.15)) (justify left bottom))
		(uuid "d2667fd3-e092-448a-b311-a88edd4fe22e")
	)
	(text "Phase 2: 49.5 x 21.0 mm autoroute envelope; 49.5 x 21.6 mm final release after edge-margin expansion. Four layers, top-side assembly, USB pairs over continuous GND, ESD at connector mouths, crystal adjacent to U1."
		(exclude_from_sim no)
		(at 16.51 217.17 0)
		(effects (font (size 1.15 1.15)) (justify left bottom))
		(uuid "f1daaba9-f4cc-4ffb-af3e-6e121e228db9")
	)
